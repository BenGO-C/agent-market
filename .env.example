# Server
PORT=3000
HOST=0.0.0.0
JWT_SECRET=change_this_to_a_random_secret_string

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/agent_market

# Tencent Cloud COS
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-hongkong
COS_BASE_URL=https://your-bucket-1234567890.cos.ap-hongkong.myqcloud.com

# App
APP_NAME=AgentMarket
MAX_FILE_SIZE_MB=50
